#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-stale [--pretty] [--hours N]
Options:
  --pretty     Human-readable table
  --hours N    Hours threshold (default: 24)
HELP
}

source "$SCRIPT_DIR/db-common"

HOURS=24
while [[ $# -gt 0 ]]; do
    case "$1" in
        --hours) shift; HOURS="$1"; validate_int "--hours" "$HOURS"; shift ;;
        --help|-h) show_help; exit 0 ;;
        *) break ;;
    esac
done

parse_common_flags "$@"

d1_query "
SELECT mmsi, name, vessel_type, length, of_interest, last_seen,
       CAST((julianday('now') - julianday(last_seen)) * 24 AS INTEGER) as hours_ago
FROM vessels
WHERE last_seen < datetime('now', '-$HOURS hours')
ORDER BY last_seen ASC
"
