#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-tiers [--pretty]
Options:
  --pretty     Human-readable table
HELP
}

source "$SCRIPT_DIR/db-common"
parse_common_flags "$@"

d1_query "
SELECT tier, COUNT(*) as pos_count,
       COUNT(DISTINCT mmsi) as distinct_vessels,
       ROUND(AVG(speed), 1) as avg_speed_kn,
       MIN(ts) as first_ts, MAX(ts) as last_ts
FROM positions
GROUP BY tier
ORDER BY tier
"
