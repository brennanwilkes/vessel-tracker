#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-positions <mmsi> [--pretty] [--limit N] [--tier direct|local|global]
Options:
  --pretty      Human-readable table
  --limit N     Maximum rows (default: 50)
  --tier TIER   Filter to one scan tier
HELP
}

source "$SCRIPT_DIR/db-common"

MMSI="${1:-}"
if [[ -z "$MMSI" ]]; then
    echo "Error: MMSI argument is required" >&2
    show_help >&2
    exit 1
fi
shift
validate_mmsi "$MMSI"

LIMIT=50
TIER=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --limit) shift; LIMIT="$1"; validate_int "--limit" "$LIMIT"; shift ;;
        --tier)  shift; TIER="$1"; shift ;;
        --help|-h) show_help; exit 0 ;;
        *) break ;;
    esac
done

parse_common_flags "$@"

SQL="SELECT p.id, p.mmsi, v.name,
             p.lat, p.lon, p.speed, p.heading, p.tier,
             p.ts as ts_utc
      FROM positions p
      LEFT JOIN vessels v ON v.mmsi = p.mmsi
      WHERE p.mmsi = $MMSI"

if [[ -n "$TIER" ]]; then
    SQL="$SQL AND p.tier = '$TIER'"
fi

SQL="$SQL ORDER BY p.ts DESC LIMIT $LIMIT"

d1_query "$SQL"
