#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-search <term> [--pretty] [--limit N]
Search vessels by MMSI or name fragment (case-insensitive). Results ordered
by relevance: exact MMSI > MMSI prefix > name/substring.
Options:
  --pretty     Human-readable table
  --limit N    Maximum rows (default: 30)
HELP
}

source "$SCRIPT_DIR/db-common"

TERM="${1:-}"
if [[ -z "$TERM" ]]; then
    echo "Error: search term argument is required" >&2
    show_help >&2
    exit 1
fi
shift

LIMIT=30
while [[ $# -gt 0 ]]; do
    case "$1" in
        --limit) shift; LIMIT="$1"; validate_int "--limit" "$LIMIT"; shift ;;
        --help|-h) show_help; exit 0 ;;
        *) break ;;
    esac
done

parse_common_flags "$@"

SAFE_TERM="$(sanitize_like "$TERM")"

# Match patterns: exact MMSI, MMSI prefix, name/substring
if [[ "$TERM" =~ ^[0-9]+$ ]]; then
    d1_query "
    SELECT mmsi, name, vessel_type, length, of_interest, max_extent, last_seen
    FROM vessels
    WHERE CAST(mmsi AS TEXT) LIKE '$SAFE_TERM%'
       OR UPPER(name) LIKE UPPER('%$SAFE_TERM%')
    ORDER BY
        CASE WHEN CAST(mmsi AS TEXT) = '$SAFE_TERM' THEN 0
             WHEN CAST(mmsi AS TEXT) LIKE '$SAFE_TERM%' THEN 1
             ELSE 2
        END,
        last_seen DESC
    LIMIT $LIMIT
    "
else
    d1_query "
    SELECT mmsi, name, vessel_type, length, of_interest, max_extent, last_seen
    FROM vessels
    WHERE UPPER(name) LIKE UPPER('%$SAFE_TERM%')
    ORDER BY last_seen DESC
    LIMIT $LIMIT
    "
fi
