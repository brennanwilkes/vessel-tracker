#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-timeline [--pretty] [--limit N] [--tier direct|local|global]
Options:
  --pretty      Human-readable table
  --limit N     Maximum rows (default: 50)
  --tier TIER   Filter to one scan tier
HELP
}

source "$SCRIPT_DIR/db-common"

LIMIT=50
TIER=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --limit) shift; LIMIT="$1"; validate_int "--limit" "$LIMIT"; shift ;;
        --tier)  shift; TIER="$1"; shift ;;
        --help|-h) show_help; exit 0 ;;
        *) break ;;
    esac
done

parse_common_flags "$@"

SQL="SELECT p.id, p.mmsi, v.name, p.lat, p.lon, p.speed, p.tier, p.ts as ts_utc
      FROM positions p
      LEFT JOIN vessels v ON v.mmsi = p.mmsi"

if [[ -n "$TIER" ]]; then
    SQL="$SQL WHERE p.tier = '$TIER'"
fi

SQL="$SQL ORDER BY p.ts DESC LIMIT $LIMIT"

d1_query "$SQL"
