#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-by-type [--pretty] [--min N]
Options:
  --pretty     Human-readable table instead of JSON
  --min N      Minimum vessel count to include (default: 1)
HELP
}

source "$SCRIPT_DIR/db-common"

MIN=1
while [[ $# -gt 0 ]]; do
    case "$1" in
        --min) shift; MIN="$1"; validate_int "--min" "$MIN"; shift ;;
        --help|-h) show_help; exit 0 ;;
        *) break ;;
    esac
done

parse_common_flags "$@"

d1_query "
SELECT vessel_type, COUNT(*) as cnt,
       SUM(of_interest) as of_interest_cnt
FROM vessels
WHERE vessel_type IS NOT NULL
GROUP BY vessel_type
HAVING cnt >= $MIN
ORDER BY cnt DESC
"
