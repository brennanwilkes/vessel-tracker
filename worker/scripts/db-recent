#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-recent [--pretty] [--limit N]
Options:
  --pretty     Human-readable table
  --limit N    Maximum rows (default: 50)
HELP
}

source "$SCRIPT_DIR/db-common"

LIMIT=50
while [[ $# -gt 0 ]]; do
    case "$1" in
        --limit) shift; LIMIT="$1"; validate_int "--limit" "$LIMIT"; shift ;;
        --help|-h) show_help; exit 0 ;;
        *) break ;;
    esac
done

parse_common_flags "$@"

d1_query "
SELECT mmsi, name, vessel_type, last_speed, last_seen,
       CASE WHEN last_speed >= 1.5 THEN 'moving' ELSE 'stopped' END as status
FROM vessels
ORDER BY last_seen DESC
LIMIT $LIMIT
"
