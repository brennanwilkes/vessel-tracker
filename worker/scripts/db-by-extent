#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-by-extent [--pretty]
Options:
  --pretty     Human-readable table
HELP
}

source "$SCRIPT_DIR/db-common"
parse_common_flags "$@"

d1_query "
SELECT max_extent, COUNT(*) as cnt,
       ROUND(100.0 * COUNT(*) / (SELECT COUNT(*) FROM vessels), 1) as pct
FROM vessels
WHERE max_extent IS NOT NULL
GROUP BY max_extent
ORDER BY cnt DESC
"
