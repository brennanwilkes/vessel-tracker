#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/db-common"
parse_common_flags "$@"
d1_query "
SELECT 'total_vessels' as metric, COUNT(*) as value FROM vessels;
SELECT 'of_interest' as metric, SUM(of_interest) as value FROM vessels;
SELECT 'not_of_interest' as metric, COUNT(*) - SUM(of_interest) as value FROM vessels;
SELECT 'total_positions' as metric, COUNT(*) as value FROM positions;
SELECT 'direct_positions' as metric, COUNT(*) as value FROM positions WHERE tier = 'direct';
SELECT 'local_positions' as metric, COUNT(*) as value FROM positions WHERE tier = 'local';
SELECT 'global_positions' as metric, COUNT(*) as value FROM positions WHERE tier = 'global';
SELECT 'vessels_with_positions' as metric, COUNT(DISTINCT mmsi) as value FROM positions;
SELECT 'max_extent_direct' as metric, COUNT(*) as value FROM vessels WHERE max_extent = 'direct';
SELECT 'max_extent_local' as metric, COUNT(*) as value FROM vessels WHERE max_extent = 'local';
SELECT 'max_extent_global' as metric, COUNT(*) as value FROM vessels WHERE max_extent = 'global';
"
