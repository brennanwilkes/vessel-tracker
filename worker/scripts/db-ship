#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-ship <mmsi> [--pretty]
Options:
  --pretty     Human-readable tables
HELP
}

source "$SCRIPT_DIR/db-common"

MMSI="${1:-}"
if [[ -z "$MMSI" ]]; then
    echo "Error: MMSI argument is required" >&2
    show_help >&2
    exit 1
fi
shift
validate_mmsi "$MMSI"

parse_common_flags "$@"

d1_query "
SELECT * FROM vessels WHERE mmsi = $MMSI;
SELECT tier, COUNT(*) as pos_count,
       MIN(ts) as first_ts, MAX(ts) as last_ts
FROM positions WHERE mmsi = $MMSI
GROUP BY tier
ORDER BY tier;
SELECT COUNT(*) as total_positions FROM positions WHERE mmsi = $MMSI;
"
