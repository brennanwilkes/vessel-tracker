#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() { cat <<'HELP'
Usage: db-list-ships [--pretty] [--limit N]
Options:
  --pretty     Human-readable table instead of JSON
  --limit N    Maximum rows (default: all)
HELP
}

source "$SCRIPT_DIR/db-common"

LIMIT=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --limit) shift; LIMIT="$1"; validate_int "--limit" "$LIMIT"; shift ;;
        --help|-h) show_help; exit 0 ;;
        *) break ;;
    esac
done

parse_common_flags "$@"

SQL="SELECT mmsi, name, vessel_type, length, of_interest, max_extent,
             last_seen as last_seen_utc, times_seen,
             COALESCE(direct_entry_count, 0) as direct_entry_count
      FROM vessels ORDER BY last_seen DESC"

if [[ -n "$LIMIT" ]]; then
    SQL="$SQL LIMIT $LIMIT"
fi

d1_query "$SQL"
